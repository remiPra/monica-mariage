---
import Layout from '../../../layouts/Layout.astro';

const robe = {
  "dressName": "Hadson",
  "price": "",
  "category": "forme-sirene",
  "imageUrl": "https://res.cloudinary.com/dkbsvrpdc/image/upload/v1741182124/images_optimisees/jzsgjviy00uvs4cjujvs.webp",
  "width": 1333,
  "height": 2000,
  "id": 5,
  "optimizedImages": {
    "slider": {
      "desktop": "/images/robes/slider/desktop/monica-mariage-robe-de-mariee-sirene-hadson-5-slider-desktop.webp",
      "mobile": "/images/robes/slider/mobile/monica-mariage-robe-de-mariee-sirene-hadson-5-slider-mobile.webp"
    },
    "gallery": {
      "desktop": "/images/robes/gallery/desktop/monica-mariage-robe-de-mariee-sirene-hadson-5-gallery-desktop.webp",
      "tablet": "/images/robes/gallery/tablet/monica-mariage-robe-de-mariee-sirene-hadson-5-gallery-tablet.webp",
      "mobile": "/images/robes/gallery/mobile/monica-mariage-robe-de-mariee-sirene-hadson-5-gallery-mobile.webp"
    },
    "thumbnail": "/images/robes/thumbnails/monica-mariage-robe-de-mariee-sirene-hadson-5-thumb.webp"
  },
  "urlBest": "monica-mariage-robe-de-mariee-sirene-hadson-5",
  "title": "Robe Sirène Dentelle Monica Mariage Toulouse",
  "metaDescription": "Sublimez votre mariage avec cette robe sirène en dentelle, une création Monica Mariage près de Toulouse.",
  "descriptionCourte": "Craquez pour cette sublime robe de mariée sirène signée Monica Mariage, près de Toulouse.",
  "altOptimized": "robe de mariée sirène Monica Mariage Toulouse"
};
---

<Layout title={robe.title} description={robe.metaDescription}>
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/keen-slider@6.8.5/keen-slider.min.css"
  />

  <section class="mt-[100px]   md:flex bg-gradient-to-b from-white to-[#FDE9E6]">
    <div class="w-full md:w-2/3">
    <div class="max-w-[400px] mx-auto text-center">
      
      <div id="my-keen-slider" class="keen-slider">
        <div class="keen-slider__slide">
          <img src={robe.optimizedImages.gallery.desktop} alt={robe.altOptimized} />
        </div>
        <div class="keen-slider__slide">
          <img src={robe.optimizedImages.gallery.desktop} alt={robe.altOptimized} />
        </div>
        <div class="keen-slider__slide">
          <img src={robe.optimizedImages.gallery.desktop} alt={robe.altOptimized} />
        </div>
        <div class="keen-slider__slide">
          <img src={robe.optimizedImages.gallery.desktop} alt={robe.altOptimized} />
        </div>
      </div>
    </div>
  </div>
  <div class="w-full md:w-1/3">
    blblassss
  </div>

  </section>

  <script is:inline src="https://cdn.jsdelivr.net/npm/keen-slider@6.8.5/keen-slider.min.js"></script>
  <script is:inline>
    var slider = new KeenSlider("#my-keen-slider", {
      loop: true,
    })
  </script>

  <style>
    .keen-slider {
  height: auto; /* Laisse la hauteur s'adapter */
  max-height: 90vh; /* Évite que le slider ne prenne trop de place */
  overflow: hidden;

}

.keen-slider__slide {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.keen-slider__slide img {
  width: 100%;
  height: auto;
  object-fit: contain; /* Évite le recadrage de l'image */
  max-height: 100vh; /* Garde un bon ratio sans couper */
}

    
    .slide1 {
      background: linear-gradient(135deg, #FDE9E6 0%, #f8d1ca 100%);
    }
    
    .slide2 {
      background: linear-gradient(135deg, #f8d1ca 0%, #f3b9af 100%);
    }
    
    .slide3 {
      background: linear-gradient(135deg, #f3b9af 0%, #eea194 100%);
    }
    
    .slide4 {
      background: linear-gradient(135deg, #eea194 0%, #e98979 100%);
    }
    
    /* Font for the cursive title */
    .font-cursive {
      font-family: 'Playfair Display', serif;
    }
  </style>
</Layout>
