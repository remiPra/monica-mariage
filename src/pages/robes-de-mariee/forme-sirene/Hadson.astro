---
import Layout from '../../../layouts/Layout.astro';

const robe = {
  "dressName": "Hadson",
  "price": "",
  "category": "forme-sirene",
  "imageUrl": "https://res.cloudinary.com/dkbsvrpdc/image/upload/v1741182124/images_optimisees/jzsgjviy00uvs4cjujvs.webp",
  "width": 1333,
  "height": 2000,
  "id": 5,
  "optimizedImages": {
    "slider": {
      "desktop": "/images/robes/slider/desktop/monica-mariage-robe-de-mariee-sirene-hadson-5-slider-desktop.webp",
      "mobile": "/images/robes/slider/mobile/monica-mariage-robe-de-mariee-sirene-hadson-5-slider-mobile.webp"
    },
    "gallery": {
      "desktop": "/images/robes/gallery/desktop/monica-mariage-robe-de-mariee-sirene-hadson-5-gallery-desktop.webp",
      "tablet": "/images/robes/gallery/tablet/monica-mariage-robe-de-mariee-sirene-hadson-5-gallery-tablet.webp",
      "mobile": "/images/robes/gallery/mobile/monica-mariage-robe-de-mariee-sirene-hadson-5-gallery-mobile.webp"
    },
    "thumbnail": "/images/robes/thumbnails/monica-mariage-robe-de-mariee-sirene-hadson-5-thumb.webp"
  },
  "urlBest": "monica-mariage-robe-de-mariee-sirene-hadson-5",
  "title": "Robe Sirène Dentelle Monica Mariage Toulouse",
  "metaDescription": "Sublimez votre mariage avec cette robe sirène en dentelle, une création Monica Mariage près de Toulouse.",
  "descriptionCourte": "Craquez pour cette sublime robe de mariée sirène signée Monica Mariage, près de Toulouse.",
  "altOptimized": "robe de mariée sirène Monica Mariage Toulouse"
};
---

<Layout title={robe.title} description={robe.metaDescription}>
  <!-- ✅ Précharge l'image principale pour améliorer le LCP -->
  <link rel="preload" as="image" href={robe.optimizedImages.gallery.desktop} type="image/webp" />

  <!-- ✅ Chargement de KeenSlider et Alpine.js -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/keen-slider@6.8.5/keen-slider.min.css" />
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>

  <section 
    class="py-12 bg-gradient-to-b from-white to-[#FDE9E6]"
    x-data="{ isLoading: true }"
    x-init="setTimeout(() => isLoading = false, 200)">
    
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="font-cursive text-5xl font-semibold text-[#af7749] mb-4">{robe.dressName}</h1>

      <!-- ✅ Mini-loader pour éviter un flash blanc -->
      <div x-show="isLoading" class="flex justify-center items-center h-[500px]">
        <div class="loader"></div>
      </div>

      <!-- ✅ Correction : Le slider doit être affiché uniquement quand il est chargé -->
      <div id="slider-wrapper" x-show="!isLoading" x-transition.opacity>
        <div id="my-keen-slider" class="keen-slider">
          <div class="keen-slider__slide">
            <img src={robe.optimizedImages.gallery.desktop} alt={robe.altOptimized} width="1333" height="2000" />
          </div>
          <div class="keen-slider__slide">
            <img src={robe.optimizedImages.gallery.desktop} alt={robe.altOptimized} width="1333" height="2000" />
          </div>
          <div class="keen-slider__slide">
            <img src={robe.optimizedImages.gallery.desktop} alt={robe.altOptimized} width="1333" height="2000" />
          </div>
        </div>
      </div>

      <p class="mt-4 text-lg text-black">{robe.descriptionCourte}</p>
      <a href="/prendre-rendez-vous">
        <button class="mt-6 bg-[#af7749] text-white py-2 px-6 rounded-lg shadow-lg hover:bg-[#925c36] transition duration-300">
          Prendre rendez-vous
        </button>
      </a>
    </div>
  </section>

  <!-- ✅ Correction : Attendre que tout soit prêt avant de lancer KeenSlider -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/keen-slider@6.8.5/keen-slider.min.js"></script>
  <script is:inline>
    document.addEventListener("DOMContentLoaded", function () {
      setTimeout(() => {
        console.log("🔥 Initialisation KeenSlider...");
        const sliderElement = document.getElementById("my-keen-slider");
        if (sliderElement) {
          new KeenSlider(sliderElement, {
            loop: true,
            slides: { perView: 1, spacing: 10 }
          });
        } else {
          console.error("⚠️ Erreur: KeenSlider introuvable !");
        }
      }, 200);
    });
  </script>

  <style>
    /* ✅ Mini-loader pour éviter un flash blanc */
    .loader {
      border: 4px solid rgba(255, 255, 255, 0.3);
      border-top: 4px solid #af7749;
      border-radius: 50%;
      width: 50px;
      height: 50px;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    /* ✅ Fixe la hauteur du slider dès le début */
    #slider-wrapper {
      min-height: 500px;
      max-height: 90vh;
      overflow: hidden;
    }

    .keen-slider {
      min-height: 500px; /* Empêche le saut de contenu */
      max-height: 90vh;
    }

    .keen-slider__slide {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
    }

    .keen-slider__slide img {
      width: 100%;
      height: auto;
      max-height: 100vh;
      object-fit: contain;
      aspect-ratio: 1333 / 2000;
    }

    /* ✅ Ajout d'une animation de fade-in */
    [x-show="!isLoading"] {
      transition: opacity 0.4s ease-in-out;
    }

    /* ✅ Typographie */
    .font-cursive {
      font-family: 'Playfair Display', serif;
    }
  </style>
</Layout>
